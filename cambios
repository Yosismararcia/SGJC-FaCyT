            with conexion.cursor() as cursor:
                cursor.execute("""
                    SELECT e.*, est.nombre AS estado_nombre 
                    FROM eventos e 
                    JOIN estados est ON e.estado_id = est.id 
                    WHERE e.id = %s AND e.creador_id = %s;
                """, (evento_id, session['usuario_id']))
